rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Private user data (SRS + gamification) ─────────────────────────────
    // Only the owner can read/write their own data.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Public progress — for admin monitoring ──────────────────────────────
    // • Any signed-in user can READ (allows admin to list all students).
    // • Only the owner can WRITE (students can only update their own record).
    match /publicProgress/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /publicProgress/{uid}/{document=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
