  "teach": {
    "type": "flashcard",
    "items": [
      {
        "front": "📏 What is Perimeter?",
        "back": "Perimeter is the total length of the boundary of a 2D shape.\nIt is measured in units like cm, m, km.\nTo find it, add up all the side lengths.",
        "hint": "Think of walking all the way around the edge of a field."
      },
      {
        "front": "🟦 Perimeter of a Rectangle",
        "back": "Formula: P = 2 × (l + b)\nWhere l = length and b = breadth.\n\nExample: l = 8 cm, b = 4 cm\nP = 2 × (8 + 4) = 2 × 12 = 24 cm",
        "hint": "A rectangle has two pairs of equal sides."
      },
      {
        "front": "🟥 Area of a Rectangle",
        "back": "Formula: A = l × b\nWhere l = length and b = breadth.\nArea is measured in square units (cm², m²).\n\nExample: l = 8 cm, b = 4 cm\nA = 8 × 4 = 32 cm²",
        "hint": "Area tells you how much surface is covered."
      },
      {
        "front": "🟪 Perimeter of a Square",
        "back": "A square has four equal sides of length s.\nFormula: P = 4 × s\n\nExample: s = 6 cm\nP = 4 × 6 = 24 cm",
        "hint": "All four sides of a square are equal."
      },
      {
        "front": "🟫 Area of a Square",
        "back": "Formula: A = s × s = s²\nWhere s = side length.\n\nExample: s = 6 cm\nA = 6² = 36 cm²",
        "hint": "Multiply the side by itself."
      },
      {
        "front": "🔺 Perimeter of a Triangle",
        "back": "Add all three sides together.\nFormula: P = a + b + c\n\nExample: sides 5 cm, 12 cm, 13 cm\nP = 5 + 12 + 13 = 30 cm",
        "hint": "Just add all sides — even if sides are unequal."
      },
      {
        "front": "🔻 Area of a Right Triangle",
        "back": "Formula: A = ½ × base × height\n\nExample: base = 8 cm, height = 6 cm\nA = ½ × 8 × 6 = 24 cm²\n\nThe base and height must be perpendicular (at 90°).",
        "hint": "The height is the perpendicular side, not the slanting side."
      },
      {
        "front": "⭕ Circumference of a Circle",
        "back": "Formula: C = 2πr  or  C = πd\nWhere r = radius, d = diameter, π = 22/7\n\nExample: r = 7 cm\nC = 2 × 22/7 × 7 = 44 cm",
        "hint": "Circumference is the perimeter of a circle."
      },
      {
        "front": "🔵 Area of a Circle",
        "back": "Formula: A = πr²\nWhere r = radius and π = 22/7\n\nExample: r = 7 cm\nA = 22/7 × 7 × 7 = 154 cm²",
        "hint": "Square the radius first, then multiply by π."
      }
    ]
  },

