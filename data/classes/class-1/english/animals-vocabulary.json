      {
        "front": "🐕 Dog",
        "back": "A dog says 'Woof!' It is a pet that barks. A baby dog is called a puppy.",
        "hint": "Man's best friend"
      },
      {
        "front": "🐈 Cat",
        "back": "A cat says 'Meow!' It is a pet that purrs. A baby cat is called a kitten.",
        "hint": "It purrs"
      },
      {
        "front": "🐄 Cow",
        "back": "A cow says 'Moo!' Cows live on farms and give us milk. A baby cow is called a calf.",
        "hint": "Gives us milk"
      },
      {
        "front": "🐔 Hen",
        "back": "A hen says 'Cluck!' Hens lay eggs. A baby chicken is called a chick.",
        "hint": "Lays eggs"
      },
      {
        "front": "🦁 Lion",
        "back": "A lion says 'Roar!' Lions are big wild cats. A baby lion is called a cub.",
        "hint": "The king of animals"
      },
      {
        "front": "🐸 Frog",
        "back": "A frog says 'Ribbit!' Frogs live near water and can jump very far.",
        "hint": "Hops and jumps"
      },
      {
        "front": "🐘 Elephant",
        "back": "An elephant makes a 'Trumpet' sound. It has a long trunk and big ears. A baby elephant is called a calf.",
        "hint": "Has a trunk"
      },
      {
        "front": "🦆 Duck",
        "back": "A duck says 'Quack!' Ducks swim in water and waddle on land.",
        "hint": "Swims in water"
      }
    ]
  },
